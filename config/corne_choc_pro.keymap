/*
 * Keebart Corne Pro BT — ZMK Keymap
 * OS input language: Swedish (macOS + Windows)
 *
 * Requires: https://github.com/joelspadin/zmk-locales
 *
 * BT profile 0 = Mac  → automatically activates MAC_OVRD layer
 * BT profile 1 = Win  → automatically activates WIN_BASE layer (no overrides)
 *
 * The only keys that differ between Mac and Windows Swedish ISO layout are
 * the < > keys (NUBS / GRAVE swap on Mac ISO). All other keys are identical.
 * MAC_OVRD is a sparse overlay layer: only those keys are defined, everything
 * else falls through transparently.
 *
 * Layer 0 — WIN_BASE  QWERTY + Swedish chars + homerow mods  (Windows default)
 * Layer 1 — LOWER     Numbers + F-key holds
 * Layer 2 — RAISE     Nav + symbols
 * Layer 3 — CODE      Brackets, braces, coding symbols
 * Layer 4 — SYSTEM    BT switch (with OS layer toggle), RGB, power
 * Layer 5 — MAC_OVRD  Mac-specific key overrides (sparse, transparent otherwise)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/ext_power.h>
#include <locale/keys_se.h>

/* ── Layer indices ───────────────────────────────────────────────────────────*/
#define WIN_BASE  0
#define LOWER     1
#define RAISE     2
#define CODE      3
#define SYS       4
#define MAC_OVRD  5

/* ── < > keycodes per OS ─────────────────────────────────────────────────────
 * Windows/Linux: SE_LT = NUBS,       SE_GT = LS(NUBS)
 * Mac ISO:       GRAVE swaps with NUBS at the hardware level, so:
 *                MAC_LT = GRAVE,      MAC_GT = LS(GRAVE)
 */
#define WIN_LT   SE_LT
#define WIN_GT   SE_GT
#define MAC_LT   GRAVE
#define MAC_GT   LS(GRAVE)

/* ── Homerow mod behavior ────────────────────────────────────────────────────
 * "balanced": quick taps = key, deliberate holds = modifier.
 * Left:  A=GUI  S=ALT  D=SHFT  F=CTRL
 * Right: J=CTRL K=SHFT L=ALT   Ö=GUI
 */
&mt {
    flavor = "balanced";
    tapping-term-ms = <240>;
    quick-tap-ms = <150>;
    require-prior-idle-ms = <100>;
};

/ {

    behaviors {
        fht: function_hold_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <220>;
            quick-tap-ms = <150>;
            bindings = <&kp>, <&kp>;
            display-name = "Function Hold-Tap";
        };
    };

    /* ── Combos ──────────────────────────────────────────────────────────────
     * LWR + RSE held together → CODE layer
     */
        combos {
            compatible = "zmk,combos";
            combo_code {
                timeout-ms = <50>;
                key-positions = <41 44>;
                bindings = <&mo CODE>;
            };
        };

    /* ── Macros ──────────────────────────────────────────────────────────────
     * sw_mac: switch to BT profile 0 AND activate MAC_OVRD layer
     * sw_win: switch to BT profile 1 AND deactivate MAC_OVRD (back to WIN_BASE)
     *
     * &to MAC_OVRD makes it the new "base" — all layers still work on top of it
     * because MAC_OVRD is the highest-numbered layer and only overrides < >
     *
     * We use &df (default layer) instead of &to so momentary layers still work:
     *   &df MAC_OVRD  sets MAC_OVRD as the persistent default layer
     *   &df WIN_BASE  sets WIN_BASE as the persistent default layer
     */
    macros {
        sw_mac: sw_mac {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt BT_SEL 0>, <&to WIN_BASE>, <&tog MAC_OVRD>;
        };
        sw_win: sw_win {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt BT_SEL 1>, <&to WIN_BASE>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        /* ── Layer 0: WIN_BASE ───────────────────────────────────────────────
         *
         * ┌──────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
         * │  TAB │  Q   │  W   │  E   │  R   │  T   │   │  Y   │  U   │  I   │  O   │  P   │ BKSP │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ CTRL │GUI/A │ALT/S │SHF/D │CTL/F │  G   │   │  H   │CTL/J │SHF/K │ALT/L │GUI/Ö │  Ä   │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ SHFT │  Z   │  X   │  C   │  V   │  B   │   │  N   │  M   │  ,   │  .   │  -   │ ESC  │
         * └──────┴──────┴──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┴──────┴──────┴──────┘
         *                      │lt SYS│ LWR  │ SPC  │   │ RET  │ RSE  │ ALT  │
         *                      └──────┴──────┴──────┘   └──────┴──────┴──────┘
         */
        win_base_layer {
            bindings = <
  &kp TAB    &kp Q          &kp W          &kp E           &kp R           &kp T        &trans     &trans     &kp Y      &kp U           &kp I           &kp O          &kp P                  &kp BSPC
  &kp LCTRL  &mt LGUI A     &mt LALT S     &mt LSHFT D     &mt LCTRL F     &kp G        &trans     &trans     &kp H      &mt RCTRL J     &mt RSHFT K     &mt RALT L     &mt RGUI SE_O_UMLAUT   &kp SE_A_UMLAUT
  &kp LSHFT  &kp Z          &kp X          &kp C           &kp V           &kp B                                &kp N      &kp M           &kp COMMA       &kp DOT        &kp SE_MINUS            &kp ESC
                                                              &lt SYS LGUI    &mo LOWER    &kp SPACE                           &kp RET    &mo RAISE       &kp RALT
            >;
        };

        /* ── Layer 1: LOWER ──────────────────────────────────────────────────
         *
         * Tap for symbols/numbers. Hold the top row for F1-F10, and hold
         * the 1/2 keys for F11/F12.
         *
         * ┌──────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
         * │      │  !   │  "   │  #   │  ¤   │  %   │   │  &   │  /   │  (   │  )   │  =   │ BKSP │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ CTRL │  1   │  2   │  3   │  4   │  5   │   │  6   │  7   │  8   │  9   │  0   │  +   │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ SHFT │  @   │  $   │  *   │  ?   │      │   │      │      │  ;   │  :   │  _   │      │
         * └──────┴──────┴──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┴──────┴──────┴──────┘
         *                      │      │(held)│ SPC  │   │ RET  │      │ ALT  │
         *                      └──────┴──────┴──────┘   └──────┴──────┴──────┘
         */
        lower_layer {
            bindings = <
  &trans     &fht F1 SE_EXCL  &fht F2 SE_DQT  &fht F3 SE_HASH  &fht F4 SE_CURREN  &fht F5 SE_PRCNT   &trans     &trans     &fht F6 SE_AMPS  &fht F7 SE_FSLH  &fht F8 SE_LPAR  &fht F9 SE_RPAR  &fht F10 SE_EQUAL      &kp BSPC
  &kp LCTRL  &fht F11 SE_N1   &fht F12 SE_N2  &kp SE_N3        &kp SE_N4          &kp SE_N5          &trans     &trans     &kp SE_N6        &kp SE_N7        &kp SE_N8       &kp SE_N9        &kp SE_N0              &kp SE_PLUS
  &kp LSHFT  &kp SE_AT    &kp SE_DLLR  &kp SE_ASTRK &kp SE_QMARK   &trans                                   &trans       &trans       &kp SE_SEMI  &kp SE_COLON &kp SE_UNDER           &trans
                                                              &trans       &trans        &kp SPACE                           &kp RET    &trans          &kp RALT
            >;
        };

        /* ── Layer 2: RAISE ──────────────────────────────────────────────────
         *
         * ┌──────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
         * │      │  !   │  "   │  #   │  ¤   │  %   │   │  ^   │  &   │  *   │  (   │  )   │  Å   │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ CTRL │  @   │  $   │  ?   │  /   │      │   │  ←   │  ↓   │  ↑   │  →   │  \   │  `   │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │ SHFT │      │      │      │      │      │   │  _   │  +   │  {   │  }   │  |   │  ~   │
         * └──────┴──────┴──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┴──────┴──────┴──────┘
         *                      │      │      │ SPC  │   │ RET  │(held)│ ALT  │
         *                      └──────┴──────┴──────┘   └──────┴──────┴──────┘
         */
        raise_layer {
            bindings = <
  &trans     &kp SE_EXCL  &kp SE_DQT   &kp SE_HASH   &kp SE_CURREN  &kp SE_PRCNT      &trans     &trans     &kp SE_CARET  &kp SE_AMPS  &kp SE_ASTRK  &kp SE_LPAR  &kp SE_RPAR          &kp SE_A_RING
  &kp LCTRL  &kp SE_AT    &kp SE_DLLR  &kp SE_QMARK  &kp SE_FSLH    &trans            &trans     &trans     &kp LEFT      &kp DOWN     &kp UP        &kp RIGHT    &kp SE_BSLH          &kp SE_GRAVE
  &kp LSHFT  &trans       &trans       &trans        &trans         &trans                                    &kp SE_UNDER  &kp SE_PLUS  &kp SE_LBRC   &kp SE_RBRC  &kp SE_PIPE          &kp SE_TILDE
                                                              &trans       &trans        &kp SPACE                           &kp RET    &trans             &kp RALT
            >;
        };

        /* ── Layer 3: CODE ───────────────────────────────────────────────────
         * Activated by holding LWR + RSE simultaneously.
         *
         * ┌──────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
         * │  `   │      │      │      │      │      │   │      │  [   │  ]   │      │      │  ~   │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │      │  @   │  $   │  *   │  ?   │  `   │   │  |   │  {   │  }   │      │      │  \   │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │      │      │      │      │      │      │   │      │  (   │  )   │  <   │  >   │      │
         * └──────┴──────┴──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┴──────┴──────┴──────┘
         *                      │      │(held)│      │   │      │(held)│      │
         *                      └──────┴──────┴──────┘   └──────┴──────┴──────┘
         *
         * < > use WIN keycodes here. On Mac, MAC_OVRD layer overrides them.
         */
        code_layer {
            bindings = <
  &kp SE_GRAVE  &trans      &trans       &trans        &trans        &trans      &trans     &trans     &kp SE_LBKT  &kp SE_RBKT  &trans         &trans        &kp SE_TILDE       &trans
  &trans        &kp SE_AT   &kp SE_DLLR  &kp SE_ASTRK  &kp SE_QMARK  &kp SE_GRAVE      &trans     &trans     &kp SE_PIPE  &kp SE_LBRC  &kp SE_RBRC   &trans        &trans             &kp SE_BSLH
  &trans        &trans      &trans       &trans        &trans        &trans                                &trans       &kp SE_LPAR  &kp SE_RPAR   &kp WIN_LT    &kp WIN_GT         &trans
                                                                &trans        &mo CODE      &kp SPACE                         &kp RET    &mo CODE           &trans
            >;
        };

        /* ── Layer 4: SYSTEM ─────────────────────────────────────────────────
         * Activated by holding GUI (left thumb).
         *
         * ┌──────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
         * │      │      │      │      │      │      │   │      │RGB H-│RGB H+│      │      │RGBTOG│
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │      │UNLOCK│EP OFF│EP ON │      │      │   │      │RGB S-│RGB S+│RGB B-│RGB B+│      │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │      │BTCLR │      │      │sw_mac│sw_win│   │      │EFF-  │EFF+  │      │      │      │
         * └──────┴──────┴──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┴──────┴──────┴──────┘
         *                      │(held)│      │      │   │      │      │      │
         *                      └──────┴──────┴──────┘   └──────┴──────┴──────┘
         *
         * sw_mac = BT_SEL 0 + switch to Mac mode  (profile 0 = Mac)
         * sw_win = BT_SEL 1 + switch to Win mode  (profile 1 = Windows)
         */
        sys_layer {
            bindings = <
  &trans  &trans           &trans             &trans             &trans     &trans        &trans     &trans     &rgb_ug RGB_HUD  &rgb_ug RGB_HUI  &trans           &trans           &rgb_ug RGB_TOG    &trans
  &trans  &studio_unlock   &ext_power EP_OFF  &ext_power EP_ON   &trans     &trans        &trans     &trans     &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2     &bt BT_SEL 3     &bt BT_SEL 4       &trans
  &trans  &bt BT_CLR       &trans             &trans             &sw_mac    &sw_win                              &trans           &rgb_ug RGB_EFR  &rgb_ug RGB_EFF  &trans           &trans             &trans
                                                                &trans      &trans        &trans                           &trans           &trans             &trans
            >;
        };

        /* ── Layer 5: MAC_OVRD ───────────────────────────────────────────────
         * Activated by sw_mac macro (BT profile 0).
         * Deactivated by sw_win macro (returns to WIN_BASE as default).
         *
         * This is a SPARSE layer — only the keys that differ on Mac ISO are
         * defined. Everything else is &trans, falling through to WIN_BASE.
         *
         * The only difference between Swedish Mac ISO and Windows ISO is the
         * < > key pair: Mac swaps GRAVE and NUBS at the hardware level.
         *
         * BASE layer < > positions: bottom row cols 9+10 (key indices 33, 34)
         * CODE layer < > positions: same physical keys, overridden below too.
         *
         * ┌──────┬──────┬──────┬──────┬──────┬──────┐   ┌──────┬──────┬──────┬──────┬──────┬──────┐
         * │      │      │      │      │      │      │   │      │      │      │      │      │      │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │      │      │      │      │      │      │   │      │      │      │      │      │      │
         * ├──────┼──────┼──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┼──────┼──────┼──────┤
         * │      │      │      │      │      │      │   │      │      │      │MAC < │MAC > │      │
         * └──────┴──────┴──────┼──────┼──────┼──────┤   ├──────┼──────┼──────┴──────┴──────┴──────┘
         *                      │      │      │      │   │      │      │      │
         *                      └──────┴──────┴──────┘   └──────┴──────┴──────┘
         *
         * Note: The CODE layer's < > also need Mac overrides. Since CODE is
         * activated via &mo (momentary), it sits above MAC_OVRD in the stack.
         * MAC_OVRD cannot override CODE layer keys — so < > in CODE are handled
         * by checking which default layer is active. The simplest fix is to
         * duplicate the CODE layer into a MAC_CODE layer triggered by the same
         * LWR+RSE combo when MAC_OVRD is the default. However, ZMK combos are
         * not default-layer-aware. The practical workaround: if you use Mac and
         * need < > in the CODE layer, use LOWER+RAISE to reach this base layer's
         * < > keys on the bottom row, or add a second combo for mac_code.
         * For most users the bottom-row < > (this layer) are sufficient.
         */
        mac_ovrd_layer {
            bindings = <
  &trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans        &trans        &trans  &trans  &trans
  &trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans        &trans        &trans  &trans  &trans
  &trans  &trans  &trans  &trans  &trans  &trans                      &trans  &trans        &trans        &kp MAC_LT  &kp MAC_GT  &trans
                           &trans  &trans  &trans                      &trans  &trans        &trans
            >;
        };

    }; /* keymap */
}; /* / */
